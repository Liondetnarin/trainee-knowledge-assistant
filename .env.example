# Environment — copy to .env at repo root

# AI Provider: openai | anthropic | openrouter
AI_PROVIDER=openrouter
AI_API_KEY=sk-or-v1-your-openrouter-key-here
# OpenRouter model slug — see https://openrouter.ai/models
# Examples: openai/gpt-4o-mini | google/gemma-2-9b-it:free
AI_MODEL=openai/gpt-4o-mini
# Optional — used for OpenRouter app attribution headers
APP_URL=http://localhost:3000

# Session (generate: openssl rand -base64 32)
SESSION_SECRET=change-me-to-random-32-chars-minimum

# Database (SQLite file inside container volume)
DATABASE_URL=file:./data/app.db

# Upload limits
UPLOAD_MAX_MB=10
UPLOAD_DIR=./data/uploads

# App
NODE_ENV=production
PORT=3000
