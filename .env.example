# Environment — copy to .env at repo root

# AI Provider: groq | gemini | openai | anthropic
#
# Free-tier options (pick one):
#   groq       — very fast, generous free tier (llama-3.3-70b-versatile, llama-3.1-8b-instant)
#     key: https://console.groq.com/keys (gsk_...)
#   gemini     — Google AI Studio free tier (gemini-2.0-flash and newer)
#     key: https://aistudio.google.com/apikey
AI_PROVIDER=groq
AI_API_KEY=gsk_your-groq-key-here

# Model — must match the provider above
# groq:       llama-3.3-70b-versatile | llama-3.1-8b-instant
# gemini:     gemini-2.0-flash
# openai:     gpt-4o-mini
AI_MODEL=llama-3.3-70b-versatile

# Used to decide whether session cookies require HTTPS (secure flag)
APP_URL=http://localhost:3000

# Session (generate: openssl rand -base64 32)
SESSION_SECRET=change-me-to-random-32-chars-minimum

# Database (SQLite file inside container volume)
DATABASE_URL=file:./data/app.db

# Upload limits
UPLOAD_MAX_MB=10
UPLOAD_DIR=./data/uploads

# App
NODE_ENV=production
PORT=3000
